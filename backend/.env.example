PORT = 5000
NODE_ENV = development
TIME_ZONE = Asia/Kolkata
MONGO_URI = mongodb://127.0.0.1:27017/service_manage?replicaSet=rs0
JWT_SECRET = change-this-secret
CUSTOMER_JWT_SECRET = change-this-secret
SERVICE_PROVIDER_JWT_SECRET = change-this-secret
OTP_EXPIRY_MINUTES = 10
# Comma-separated for multiple web origins (CORS + Socket.IO). Must not be empty in production.
FRONTEND_URL = http://localhost:3000
# Optional: public API base used when normalizing uploaded file URLs for deletion (see storage.deleteFile).
BASEURL =
X_API_KEY = x-api-key-change-this-secret
SMS_API_KEY =   
ALLOW_DB_SEED = false
SHOW_ERROR = true
CROSS_ORIGIN_COOKIES = false
ENABLE_GOOGLE_DNS = false
COOKIE_DOMAIN = 
# Firebase Cloud Messaging - path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH = ./firebase-service-account.json