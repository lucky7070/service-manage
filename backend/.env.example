PORT = 5000
NODE_ENV = development
MONGO_URI = mongodb://127.0.0.1:27017/service_manage
JWT_SECRET = change-this-secret
CUSTOMER_JWT_SECRET = change-this-secret
SERVICE_PROVIDER_JWT_SECRET = change-this-secret
OTP_EXPIRY_MINUTES = 10
FRONTEND_URL = http://localhost:3000
X_API_KEY = x-api-key-change-this-secret
SMS_API_KEY =   
ALLOW_DB_SEED = false
SHOW_ERROR = true

# When the Next frontend and this API use different origins (different host or scheme/port in production),
# set to true so auth cookies use SameSite=None; Secure and work with axios withCredentials.
# Leave unset for same-origin via reverse proxy (e.g. one domain serving both app and /api).
CROSS_ORIGIN_COOKIES = false