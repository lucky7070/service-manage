{
  "name": "customer_app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:prod": "cross-env NODE_ENV=production expo start -c",
    "android": "expo run:android",
    "android:prod": "cross-env NODE_ENV=production expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:prod": "cross-env NODE_ENV=production expo prebuild --clean",
    "apk:local": "cross-env NODE_ENV=production cmd /c \"cd android && gradlew.bat assembleRelease\"",
    "apk:preview": "eas build -p android --profile preview",
    "aab:local": "cross-env NODE_ENV=production cmd /c \"cd android && gradlew.bat bundleRelease\"",
    "aab:production": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "axios": "^1.16.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "^0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "formik": "^2.4.9",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "eas-cli": "^20.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
