# Copy these four lines into android/gradle.properties (optional if credentials.json exists).
# Keystore path is relative to android/app/ — or use credentials.json at project root (EAS export).

# SERVA_UPLOAD_STORE_FILE=../../credentials/android/keystore.jks
# SERVA_UPLOAD_KEY_ALIAS=your-key-alias
# SERVA_UPLOAD_STORE_PASSWORD=your-store-password
# SERVA_UPLOAD_KEY_PASSWORD=your-key-password
