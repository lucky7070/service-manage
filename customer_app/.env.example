# Use your PC's LAN IP (ipconfig → IPv4). Phone and PC must be on the same Wi‑Fi.
# Do not use localhost — it won't work on a physical device or Expo Go.
EXPO_PUBLIC_API_URL = http://192.168.1.3:5000/api
EXPO_PUBLIC_UPLOAD_URL = http://192.168.1.3:5000/uploads
EXPO_PUBLIC_SOCKET_URL = http://192.168.1.3:5000
EXPO_PUBLIC_WEB_URL = http://192.168.1.3:3000
EXPO_PUBLIC_API_LICENCE = your-x-api-key-from-backend-env
EXPO_PUBLIC_LOG_ERRORS_IN_CONSOLE = false
