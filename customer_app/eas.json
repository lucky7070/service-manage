{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "development"
            },
            "android": {
                "buildType": "apk"
            }
        },
        "preview": {
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production"
            },
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production"
            },
            "android": {
                "buildType": "apk"
            }
        }
    }
}
